DATABASE_URL=postgres://herediano:change-me@127.0.0.1:5441/herediano
HEREDIANO_SMTP_HOST=127.0.0.1
HEREDIANO_SMTP_PORT=1587
HEREDIANO_SMTP_SECURE=false
HEREDIANO_MAIL_FROM="Club Sport Herediano" <herediano@milocalhost.work>
HEREDIANO_APP_URL=https://herediano.milocalhost.work

# Optional when connecting directly to an authenticated SMTP provider.
# HEREDIANO_SMTP_USER=
# HEREDIANO_SMTP_PASS=

# WhatsApp (Meta Cloud API). Requiere numero de negocio verificado y plantilla
# aprobada con header de imagen (ver server/modules/entradas/entradas.whatsapp.ts).
WHATSAPP_ENABLED=false
# WHATSAPP_PHONE_ID=
# WHATSAPP_TOKEN=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_TEMPLATE_ENTRADAS=entrada_confirmacion
# WHATSAPP_TEMPLATE_LANG=es

# ── Pagos (Stripe) ──────────────────────────────────────────────────
# Pasarela activa. Hoy solo 'stripe'.
HEREDIANO_PAYMENTS_PROVIDER=stripe
# Usar SIEMPRE llaves de prueba (sk_test_...) en este demo; el servidor
# aborta el arranque si detecta una llave de produccion (sk_live_...).
HEREDIANO_STRIPE_SECRET_KEY=sk_test_reemplaza.con.tu.llave.de.prueba
# Secret del webhook: lo da `stripe listen` (local) o el dashboard (deploy).
HEREDIANO_STRIPE_WEBHOOK_SECRET=whsec_reemplaza.con.tu.secret.de.webhook
# Moneda de cobro (ISO 4217, minusculas).
HEREDIANO_STRIPE_CURRENCY=crc

# ── Agentic harness ────────────────────────────────────────────────
# Never commit real webhook URLs or API keys. Set these only in local env/CI.
# DISCORD_WEBHOOK_URL=
# OPENAI_API_KEY=
