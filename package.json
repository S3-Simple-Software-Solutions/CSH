{
  "name": "app_csh",
  "version": "1.0.0",
  "description": "Cached Club Sport Herediano proxy with login, admin shell, and parking management module.",
  "main": "dist-server/index.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:local": "docker compose up -d && concurrently -n servidor,frontend -c cyan,yellow \"npm run dev:server\" \"npm run dev\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist-server/index.js",
    "check": "tsc -p tsconfig.server.json --noEmit && npm run build:client",
    "test:unit": "DATABASE_URL=postgres://unit:unit@localhost:5432/unit vitest run --exclude=dist-server/**",
    "sync:branches": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-branches.ps1",
    "finish:feature": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/finish-feature.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthonyOviedo/CSH.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/anthonyOviedo/CSH/issues"
  },
  "homepage": "https://github.com/anthonyOviedo/CSH#readme",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.17.0",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
