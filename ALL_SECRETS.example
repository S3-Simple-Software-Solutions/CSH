# ALL_SECRETS.example
# Copy to ALL_SECRETS and fill in real values (ALL_SECRETS is gitignored).
#
# Upload the whole file as ONE GitHub secret named ALL_SECRETS:
#   gh secret set ALL_SECRETS --body "$(cat ALL_SECRETS)" --repo S3-Simple-Software-Solutions/CSH
#
# When ngrok restarts, update NGROK_HOST + NGROK_PORT and re-run the line above.

# ── SSH / ngrok ───────────────────────────────────────────────────────────────
# Run: ngrok tcp 22  →  output: tcp://0.tcp.ngrok.io:12345
NGROK_HOST=0.tcp.ngrok.io
NGROK_PORT=12345
DEPLOY_USER=tony

# Generate key once:
#   ssh-keygen -t ed25519 -C "github-deploy" -f ~/.ssh/github_deploy -N ""
#   cat ~/.ssh/github_deploy.pub >> ~/.ssh/authorized_keys
#   base64 -w0 ~/.ssh/github_deploy   ← paste the output below (single line)
DEPLOY_SSH_KEY_B64=LS0tLS1CRUdJTiBPUEVOU1NIIFBSSVZBVEUgS0VZLS0tLS0...

# ── App / Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://herediano:change-me@127.0.0.1:5441/herediano

# ── Email / SMTP ──────────────────────────────────────────────────────────────
HEREDIANO_SMTP_HOST=127.0.0.1
HEREDIANO_SMTP_PORT=1587
HEREDIANO_SMTP_SECURE=false
HEREDIANO_MAIL_FROM=Club Sport Herediano <herediano@milocalhost.work>
HEREDIANO_APP_URL=https://herediano.milocalhost.work
# HEREDIANO_SMTP_USER=
# HEREDIANO_SMTP_PASS=

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Requiere numero de negocio verificado y plantilla aprobada en Meta.
WHATSAPP_ENABLED=false
# WHATSAPP_PHONE_ID=
# WHATSAPP_TOKEN=
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_TEMPLATE_ENTRADAS=entrada_confirmacion
# WHATSAPP_TEMPLATE_LANG=es

# ── Pagos (Stripe) ────────────────────────────────────────────────────────────
# Demo: usar llaves de prueba (sk_test_...). El server aborta con sk_live_.
HEREDIANO_PAYMENTS_PROVIDER=stripe
HEREDIANO_STRIPE_SECRET_KEY=sk_test_reemplaza.con.tu.llave.de.prueba
HEREDIANO_STRIPE_WEBHOOK_SECRET=whsec_reemplaza.con.tu.secret.de.webhook
HEREDIANO_STRIPE_CURRENCY=crc
